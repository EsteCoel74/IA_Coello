<Window x:Class="IA_Coello.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IA_Coello"
        mc:Ignorable="d"
        Title="Esteban's IA" Height="700" Width="1000" 
        WindowStartupLocation="CenterScreen" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Gradient -->
        <Grid Grid.Row="0" Height="70">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#764ba2" Offset="0"/>
                    <GradientStop Color="#f5576c" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="Esteban's IA" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Powered by Azure AI Model Inference" FontSize="12" Foreground="#E0E0E0"/>
            </StackPanel>

            <!-- Clear Button in Top Right -->
            <Button Grid.Column="1" x:Name="ClearButton" Content="🗑️" Click="ClearButton_Click" 
                    Padding="15,15" Margin="0,0,20,0" Background="Transparent" 
                    Foreground="White" FontWeight="Bold" BorderThickness="0" 
                    Cursor="Hand" FontSize="20" VerticalAlignment="Center"
                    ToolTip="Effacer tous les messages (Ctrl+Delete)"/>
        </Grid>

        <!-- Messages Display -->
        <ListBox x:Name="MessagesListBox" Grid.Row="1" Margin="0" 
                 BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ItemContainerStyle="{StaticResource {x:Type ListBoxItem}}">
            <ListBox.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#764ba2" Offset="0"/>
                    <GradientStop Color="#f5576c" Offset="1"/>
                </LinearGradientBrush>
            </ListBox.Background>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,8,0,8" Width="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualWidth}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- User Message (Right) -->
                        <Border Grid.Column="2" Padding="12,10" Margin="40,0,20,0" 
                                CornerRadius="15" HorizontalAlignment="Right" MaxWidth="500">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#667eea" Offset="0"/>
                                    <GradientStop Color="#764ba2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" 
                                       Foreground="White" FontSize="14" Visibility="{Binding UserVisibility}"/>
                        </Border>

                        <!-- AI Message (Left) -->
                        <Border Grid.Column="0" Padding="12,10" Margin="20,0,40,0" 
                                CornerRadius="15" HorizontalAlignment="Left" MaxWidth="500">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00d4ff" Offset="0"/>
                                    <GradientStop Color="#0099ff" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" 
                                       Foreground="White" FontSize="14" Visibility="{Binding AIVisibility}"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input Area with Gradient Bottom -->
        <Grid Grid.Row="2">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#764ba2" Offset="0"/>
                    <GradientStop Color="#f5576c" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel Orientation="Vertical" Margin="20" VerticalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Input TextBox -->
                    <Border Grid.Column="0" Background="#2a2a2a" CornerRadius="25" Margin="0">
                        <TextBox x:Name="MessageInput" AcceptsReturn="False" 
                                 TextWrapping="Wrap" Padding="15,12" BorderThickness="0" 
                                 VerticalScrollBarVisibility="Auto" 
                                 Foreground="White" FontSize="14"
                                 VerticalAlignment="Center" Height="50" 
                                 TextChanged="MessageInput_TextChanged" 
                                 Background="Transparent" Text=""
                                 KeyDown="MessageInput_KeyDown"/>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
